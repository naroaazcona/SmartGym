# ============================================================
# SmartGym — Variables de entorno requeridas
# ============================================================
# Copia este archivo como .env y rellena los valores reales.
# NUNCA subas el .env al repositorio.
# ============================================================

# --- Bases de datos PostgreSQL ---
AUTH_DB_PASSWORD=cambia_esto_por_una_contraseña_segura
GYM_DB_PASSWORD=cambia_esto_por_una_contraseña_segura

# --- MongoDB ---
MONGO_ROOT_PASSWORD=cambia_esto_por_una_contraseña_segura

# --- JWT (mínimo 64 caracteres aleatorios) ---
# OBLIGATORIO: el valor por defecto de docker-compose.yml es inseguro y solo vale para desarrollo.
# Genera uno seguro con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=genera_un_secreto_largo_y_aleatorio_aqui

# --- OpenAI ---
# Obtén tu clave en: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-...

# --- Stripe ---
# Obtén tus claves en: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_PRICE_BASIC=price_...
STRIPE_PRICE_PREMIUM=price_...
STRIPE_WEBHOOK_SECRET=whsec_...
FRONTEND_URL=http://localhost:8080

# --- API Gateway ---
# URL del frontend permitida por CORS (en producción cambia a tu dominio real)
CORS_ORIGIN=http://localhost:8080

# --- pgAdmin (solo desarrollo) ---
PGADMIN_EMAIL=admin@smartgym.com
PGADMIN_PASSWORD=cambia_esto_en_produccion
